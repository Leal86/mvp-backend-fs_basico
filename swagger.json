          "200": {
            "description": "Lista de departamentos retornada com sucesso.",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Departamento"
              }
            },
            "examples": {
              "application/json": [
                {
                  "id": 1,
                  "nome": "Tecnologia da Informação",
                  "sigla": "TI",
                  "telefone": "21999999999"
                }
              ]
            }
          },
          "500": {
            "description": "Erro interno do servidor.",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      },
      "post": {
        "tags": ["📁 Departamentos"],
        "summary": "Cria um novo departamento",
        "description": "Recebe os dados de um departamento em JSON e realiza o cadastro no banco de dados.",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "Dados do departamento a ser criado.",
            "required": true,
            "schema": {
              "$ref": "#/definitions/DepartamentoRequest"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Departamento criado com sucesso.",
            "schema": {
              "$ref": "#/definitions/Departamento"
            },
            "examples": {
              "application/json": {
                "id": 1,
                "nome": "Tecnologia da Informação",
                "sigla": "TI",
                "telefone": "21999999999"
              }
            }
          },
          "400": {
            "description": "Erro de validação ou dados inválidos enviados na requisição.",
            "schema": {
              "$ref": "#/definitions/ValidationErrorResponse"
            },
            "examples": {
              "application/json": {
                "error": [
                  {
                    "loc": ["nome"],
                    "msg": "field required",
                    "type": "value_error.missing"
                  }
                ]
              }
            }
          },
          "500": {
            "description": "Erro interno do servidor.",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      }
    },

